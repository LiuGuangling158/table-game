generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  nickname      String
  email         String?   @unique
  password      String?
  avatar        String?
  openId        String?   @unique
  unionId       String?   @unique
  oauthPlatform String?
  status        UserStatus @default(OFFLINE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sentRequests     FriendRequest[] @relation("Sender")
  receivedRequests FriendRequest[] @relation("Receiver")
  friendships1     Friendship[]    @relation("User1")
  friendships2     Friendship[]    @relation("User2")
  gamePlayers      GamePlayer[]
  wonGames         GameRecord[]    @relation("Winner")
}

enum UserStatus {
  ONLINE
  OFFLINE
  IN_GAME
}

model FriendRequest {
  id         String        @id @default(uuid())
  senderId   String
  receiverId String
  status     RequestStatus @default(PENDING)
  message    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  sender   User @relation("Sender", fields: [senderId], references: [id])
  receiver User @relation("Receiver", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId, status])
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Friendship {
  id        String   @id @default(uuid())
  userId1   String
  userId2   String
  createdAt DateTime @default(now())

  user1 User @relation("User1", fields: [userId1], references: [id])
  user2 User @relation("User2", fields: [userId2], references: [id])

  @@unique([userId1, userId2])
  @@index([userId1])
  @@index([userId2])
}

model GameRoom {
  id         String     @id @default(uuid())
  gameType   GameType
  status     RoomStatus @default(WAITING)
  maxPlayers Int        @default(2)
  hostId     String
  createdAt  DateTime   @default(now())
  startedAt  DateTime?
  endedAt    DateTime?

  players GamePlayer[]
  moves   GameMove[]
  record  GameRecord?

  @@index([status])
}

enum GameType {
  GOMOKU
  XIANGQI
  CHESS
}

enum RoomStatus {
  WAITING
  PLAYING
  FINISHED
  CANCELLED
}

model GamePlayer {
  id       String      @id @default(uuid())
  roomId   String
  userId   String
  color    PlayerColor
  ready    Boolean     @default(false)
  joinedAt DateTime    @default(now())

  room GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@unique([roomId, color])
  @@unique([roomId, userId])
}

enum PlayerColor {
  BLACK
  WHITE
  RED
  BLUE
}

model GameMove {
  id         String   @id @default(uuid())
  roomId     String
  userId     String
  moveData   Json
  moveNumber Int
  createdAt  DateTime @default(now())

  room GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, moveNumber])
}

model GameRecord {
  id        String    @id @default(uuid())
  roomId    String    @unique
  gameType  GameType
  winnerId  String?
  reason    EndReason?
  duration  Int?
  createdAt DateTime  @default(now())

  room   GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  winner User?    @relation("Winner", fields: [winnerId], references: [id])
}

enum EndReason {
  CHECKMATE
  STALEMATE
  FIVE_IN_ROW
  RESIGN
  DRAW
  TIMEOUT
  DISCONNECT
}
